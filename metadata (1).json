{
  "title": "FutureBridge Signal Engine",
  "description": "Contact and signal intelligence database",
  "plugins": {
    "datasette-insert": {
      "allow_insert": true,
      "allow_upsert": true
    }
  },
  "databases": {
    "signal_engine_pe": {
      "allow_insert_row": true,
      "tables": {
        "contacts": {
          "sort_desc": "tier"
        },
        "signals": {
          "allow_insert_row": true
        }
      }
    }
  }
}
